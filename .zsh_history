from pathlib import Path\
import plistlib\
from datetime import datetime\
import subprocess\
\
sus_keywords = ['hacked', 'lolhacked', 'spam', 'curl', 'wget', 'base64', 'osascript', 'python', 'sh -c', 'bash -c']\
\
def scan_launch_dir(path):\
    p = Path(path)\
    if not p.exists():\
        return []\
    out = []\
    for f in sorted(p.glob('*.plist')):\
        rec = {'path': str(f), 'name': f.name, 'mtime': datetime.fromtimestamp(f.stat().st_mtime).isoformat(timespec='seconds')}\
        try:\
            data = plistlib.loads(f.read_bytes())\
            rec['label'] = data.get('Label')\
            prog = data.get('Program')\
            args = data.get('ProgramArguments')\
            rec['program'] = prog\
            rec['args'] = args\
            blob = ' '.join([str(x) for x in [data.get('Label'), prog, args, data.get('WatchPaths'), data.get('StartCalendarInterval')] if x is not None]).lower()\
            rec['suspicious'] = any(k in blob for k in sus_keywords)\
        except Exception as e:\
            rec['parse_error'] = str(e)\
            rec['suspicious'] = True\
        out.append(rec)\
    return out\
\
all_recs = []\
for d in [\
    '/Users/luisgbenavidesg/Library/LaunchAgents',\
    '/Library/LaunchAgents',\
    '/Library/LaunchDaemons',\
]:\
    all_recs.extend(scan_launch_dir(d))\
\
print('LAUNCH_ITEMS_TOTAL', len(all_recs))\
print('POTENTIALLY_SUSPICIOUS')\
for r in all_recs:\
    if r.get('suspicious'):\
        print(f"- {r['path']} | label={r.get('label')} | program={r.get('program')} | args={r.get('args')} | mtime={r.get('mtime')} | parse_error={r.get('parse_error')}")\
\
print('MOST_RECENT_10')\
for r in sorted(all_recs, key=lambda x: x['mtime'], reverse=True)[:10]:\
    print(f"- {r['path']} | label={r.get('label')} | program={r.get('program')} | args={r.get('args')} | mtime={r.get('mtime')}")\
\
# crontab\
print('CRONTAB_BEGIN')\
try:\
    res = subprocess.run(['crontab','-l'], capture_output=True, text=True)\
    if res.returncode == 0:\
        print(res.stdout.strip() or '[empty]')\
    else:\
        stderr = (res.stderr or '').strip()\
        print(stderr or '[no crontab]')\
except Exception as e:\
    print(f'ERROR {e}')\
print('CRONTAB_END')\
\
# shell startup suspicious patterns\
startup_files = [\
    Path('/Users/luisgbenavidesg/.zshrc'),\
    Path('/Users/luisgbenavidesg/.zprofile'),\
    Path('/Users/luisgbenavidesg/.zlogin'),\
    Path('/Users/luisgbenavidesg/.zshenv'),\
    Path('/Users/luisgbenavidesg/.bash_profile'),\
    Path('/Users/luisgbenavidesg/.bashrc'),\
]\
patterns = ['curl ', 'wget ', 'base64 ', 'osascript ', 'python ', 'ruby ', 'perl ', 'launchctl load', 'launchctl bootstrap']\
print('STARTUP_SUSPICIOUS_BEGIN')\
for sf in startup_files:\
    if not sf.exists():\
        continue\
    lines = sf.read_text(errors='ignore').splitlines()\
    for idx, line in enumerate(lines, 1):\
        low = line.lower()\
        if any(p in low for p in patterns):\
            print(f'{sf}:{idx}: {line.strip()}')\
print('STARTUP_SUSPICIOUS_END')\

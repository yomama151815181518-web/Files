from pathlib import Path\
import hashlib\
import string\
\
base = Path('/Users/luisgbenavidesg/Desktop/Desktop_Cleanup_Archive_20260608_144502')\
if not base.exists():\
    print('ARCHIVE_MISSING=1')\
    raise SystemExit(0)\
\
samples = [base/'HACKED1'/'LOLHACKED1', base/'HACKED500'/'LOLHACKED500', base/'HACKED1000'/'LOLHACKED1000']\
for p in samples:\
    b = p.read_bytes()\
    sha = hashlib.sha256(b).hexdigest()\
    printable = sum(ch in bytes(string.printable, 'ascii') for ch in b[:512])\
    ratio = printable / max(1, min(len(b), 512))\
    print(f'FILE={p.name} SIZE={len(b)} SHA256={sha} PRINTABLE_RATIO_FIRST512={ratio:.2f}')\
\
# Compare hashes across all files\
hashes = {}\
count = 0\
for hdir in sorted(base.glob('HACKED*')):\
    for f in hdir.iterdir():\
        if f.is_file():\
            hb = hashlib.sha256(f.read_bytes()).hexdigest()\
            hashes[hb] = hashes.get(hb, 0) + 1\
            count += 1\
\
print(f'TOTAL_PAYLOAD_FILES={count}')\
print(f'UNIQUE_HASHES={len(hashes)}')\
for h, c in sorted(hashes.items(), key=lambda kv: kv[1], reverse=True)[:5]:\
    print(f'HASH_COUNT {c} {h}')\

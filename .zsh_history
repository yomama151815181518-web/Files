from collections import Counter\
\
d = Path('/Users/luisgbenavidesg/Desktop')\
if not d.exists():\
    print('DESKTOP_EXISTS=0')\
    raise SystemExit(0)\
\
items = list(d.iterdir())\
files = [p for p in items if p.is_file()]\
dirs = [p for p in items if p.is_dir()]\
\
ext_counts = Counter((p.suffix.lower() if p.suffix else '[no_ext]') for p in files)\
\
print('DESKTOP_EXISTS=1')\
print(f'TOTAL_ITEMS={len(items)}')\
print(f'FILES={len(files)}')\
print(f'FOLDERS={len(dirs)}')\
print('TOP_EXTENSIONS:')\
for ext, count in ext_counts.most_common(20):\

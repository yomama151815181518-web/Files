from pathlib import Path\
import re\
\
home = Path('/Users/luisgbenavidesg')\
files = [\
    home/'.zsh_history',\
    home/'.bash_history',\
    home/'.zshrc',\
    home/'.zprofile',\
    home/'.zlogin',\
    home/'.zshenv',\
]\
patterns = [\
    re.compile(r'HACKED', re.I),\
    re.compile(r'LOLHACKED', re.I),\
    re.compile(r'mkdir\s+HACKED', re.I),\
    re.compile(r'for\s+\w+\s+in\s+\{?\d+\.\.\d+\}?', re.I),\
]\
\
for f in files:\
    if not f.exists():\
        continue\
    text = f.read_text(errors='ignore')\
    lines = text.splitlines()\
    matches = []\
    for i, line in enumerate(lines, start=1):\
        if any(p.search(line) for p in patterns):\
            matches.append((i, line.strip()))\
    if matches:\
        print(f'FILE={f}')\
        for i, line in matches[:50]:\
            print(f'  {i}: {line}')\
        if len(matches) > 50:\
            print(f'  ... {len(matches)-50} more')\

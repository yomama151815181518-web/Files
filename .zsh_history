from pathlib import Path\
from collections import Counter\
\
d = Path('/Users/luisgbenavidesg/Desktop')\
hacked = sorted([p for p in d.iterdir() if p.is_dir() and p.name.startswith('HACKED')], key=lambda p: p.name)\
\
child_name_counter = Counter()\
child_count_counter = Counter()\
examples = []\
\
for p in hacked:\
    children = list(p.iterdir())\
    child_count_counter[len(children)] += 1\
    for c in children:\
        child_name_counter[c.name] += 1\
    if len(examples) < 10:\
        examples.append((p.name, [c.name for c in children[:5]]))\
\
print('CHILD_COUNT_DISTRIBUTION:')\
for k, v in sorted(child_count_counter.items()):\
    print(f'{k}\t{v}')\
\
print('MOST_COMMON_CHILD_NAMES:')\
for name, count in child_name_counter.most_common(20):\
    print(f'{name}\t{count}')\
\
print('SAMPLES:')\
for folder, kids in examples:\
    print(folder, '->', kids)\
